{
  "name": "my-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"wait-on tcp:3001 && vite\"",
    "build": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:ci": "eslint src/components/MobileLegendsQuickTopUp.jsx vite.config.js && npm run test:run",
    "api:player:check": "node server/check-player-contract.js",
    "api:player:postman": "newman run postman/TopUpGG-Player-API.postman_collection.json -e postman/local.postman_environment.json",
    "api:player:postman:ci": "npm run api:player:postman -- --reporters cli",
    "api:player:verify": "npm run api:player:check && npm run api:player:postman:ci",
    "api:products:smoke": "node server/check-product-crud.js",
    "api:products:verify": "node server/seed-admin.js && npm run api:products:smoke",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:setup": "node server/seed-db.js",
    "server": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "newman": "^6.2.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
